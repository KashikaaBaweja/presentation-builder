# Supabase (required for auth — set in Vercel → Settings → Environment Variables)
NEXT_PUBLIC_SUPABASE_URL=
# Use your publishable key (sb_publishable_...) or legacy anon key (eyJ...)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Production site URL — required for Google OAuth redirects on Vercel
NEXT_PUBLIC_SITE_URL=https://presentation-builder-self.vercel.app

# Optional — AI generation (Phase 5)
GEMINI_API_KEY=

# 21st Agents — required for /agent chat and `npx @21st-sdk/cli deploy`
API_KEY_21ST=
