# Supabase (required for auth — set in Vercel → Settings → Environment Variables)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional — AI generation (Phase 5)
OPENAI_API_KEY=
# Use a model your OpenAI project can access (e.g. gpt-3.5-turbo-16k, gpt-5)
OPENAI_MODEL=gpt-3.5-turbo-16k
